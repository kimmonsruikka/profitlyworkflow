# Runtime environment: development | staging | production
ENVIRONMENT=development

# Broker safety gate: paper | live
# All order submission paths check this before sending to the broker.
BROKER_MODE=paper

# Broker — Alpaca (Phase 1-2)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Broker — IBKR (Phase 3+, direct routing)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql://user:password@host:5432/trading

# Redis (real-time state: PDT counter, P&L, positions, Celery broker)
REDIS_URL=redis://localhost:6379/0

# Market Data
POLYGON_API_KEY=
BENZINGA_API_KEY=
ORTEX_API_KEY=

# SEC / EDGAR
SEC_API_KEY=

# Social — Telegram alert bot (delivers signals, captures EXECUTE/PASS)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Social — Telegram pump-group monitoring (Telethon)
TELEGRAM_MONITOR_API_ID=
TELEGRAM_MONITOR_API_HASH=

# Social — Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# Social — X / StockTwits
X_API_BEARER_TOKEN=
STOCKTWITS_ACCESS_TOKEN=

# Prefect Cloud
PREFECT_API_KEY=
PREFECT_API_URL=

# Application
LOG_LEVEL=INFO
TIMEZONE=America/New_York
